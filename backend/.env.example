# Supabase Configuration
SUPABASE_URL=https://rpdqnfhfrhnzifgfmsbj.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Groq API (Whisper transcription only — free tier)
# Get key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (Classification + RAG — free tier)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (for Celery)
REDIS_URL=redis://localhost:6379

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here

# Firebase Admin SDK service account (base64-encoded JSON) — required for Step 22 FCM push
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then base64-encode: `base64 -i service-account.json | pbcopy`
FIREBASE_SERVICE_ACCOUNT_JSON=your_base64_encoded_service_account_json_here

# Tavily API (for web search fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# Environment
ENVIRONMENT=development

# macOS only: prevents SIGABRT when Celery forks after PyTorch/Metal initializes ObjC threads.
# Safe to omit on Linux (Render production).
OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
